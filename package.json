{
  "name": "pthub",
  "displayName": "PT hub",
  "version": "0.0.1",
  "description": "A web extension to manage private trackers",
  "private": true,
  "scripts": {
    "dev": "npm run clear && cross-env NODE_ENV=development run-p dev:*",
    "dev:prepare": "esno scripts/prepare.ts",
    "dev:web": "vite",
    "build": "cross-env NODE_ENV=production run-s clear build:web build:prepare",
    "build:prepare": "esno scripts/prepare.ts",
    "build:web": "vite build",
    "clear": "rimraf extension/dist extension/manifest.json",
    "lint": "eslint 'src/*.{json,ts,js,vue}'"
  },
  "dependencies": {
    "@ant-design/aliyun-theme": "^0.0.4",
    "@ant-design/icons-vue": "^6.0.1",
    "ant-design-vue": "^2.2.6",
    "axios": "^0.21.1",
    "byte-size": "^8.1.0",
    "dayjs": "^1.10.6",
    "file-size": "^1.0.0",
    "jquery": "^3.6.0",
    "lodash": "^4.17.21",
    "p-queue": "^7.1.0",
    "vue": "^3.0.5",
    "vue-i18n": "^9.1.7",
    "vuex": "^4.0.2",
    "webext-bridge": "^4.0.1",
    "webextension-polyfill": "^0.8.0"
  },
  "devDependencies": {
    "@types/file-size": "^1.0.1",
    "@types/fs-extra": "^9.0.12",
    "@types/jquery": "^3.5.6",
    "@types/less": "^3.0.3",
    "@types/node": "^16.7.1",
    "@types/webextension-polyfill": "^0.8.0",
    "@typescript-eslint/eslint-plugin": "^4.29.2",
    "@typescript-eslint/parser": "^4.29.2",
    "@vitejs/plugin-vue": "^1.3.0",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/eslint-config-standard": "^6.1.0",
    "@vue/eslint-config-typescript": "^7.0.0",
    "chokidar": "^3.5.2",
    "cross-env": "^7.0.3",
    "eslint": "^7.32.0",
    "eslint-plugin-html": "^6.1.2",
    "eslint-plugin-import": "^2.24.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-vue": "^7.16.0",
    "esno": "^0.9.1",
    "fs-extra": "^10.0.0",
    "kolorist": "^1.5.0",
    "less": "^4.1.1",
    "less-loader": "^10.0.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "typescript": "^4.3.2",
    "vite": "~2.4.4",
    "vue-router": "^4.0.11",
    "vue-tsc": "^0.2.2"
  }
}